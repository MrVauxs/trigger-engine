<div class="sidebar trigger">
    <div class="header" data-tooltip-direction="DOWN">
        <div class="controls">
            {{#if isFree}}
            <a data-action="export-data" {{{@root.i18n.tooltip 'data' }}}>
                <i class="fa-solid fa-file-export"></i>
            </a>
            {{else}}
            <a data-action="back-menu" {{{@root.i18n.tooltip 'back' }}}>
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <a data-action="edit-trigger" {{{@root.i18n.tooltip 'edit' }}}>
                <i class="fa-solid fa-pen-to-square"></i>
            </a>
            {{/if}}
        </div>
        <div class="controls">
            <a data-action="reset-trigger" {{{@root.i18n.tooltip 'reset' }}}>
                <i class="fa-solid fa-rotate-left"></i>
            </a>
            <a data-action="save-triggers" {{{@root.i18n.tooltip 'save' }}}>
                <i class="fa-solid fa-floppy-disk"></i>
            </a>
            <a data-action="collapse-window" {{{@root.i18n.tooltip 'collapse' }}}>
                <i class="fa-solid fa-compress"></i>
            </a>
        </div>
    </div>
    <div class="header sub">
        {{@root.i18n 'events'}}
    </div>
    <div class="scroll">
        <div class="list">
            {{#each events as |event|}}
            <div class="node" data-id="{{event.id}}" data-action="select-node">
                {{event.label}}
            </div>
            {{/each}}
        </div>
    </div>
    <div class="header sub">
        {{@root.i18n 'gates.title'}}
    </div>
    <div class="scroll">
        <div class="list">
            {{#each gates as |gate|}}
            <div class="node" data-id="{{gate.node.id}}" data-action="select-node" data-editable>
                <div>{{gate.node.label}}</div>
                {{#if gate.hasEntries}}
                <div class="controls">
                    <a data-action="tab-gate" {{{@root.i18n.tooltip 'gates.tab' }}}>
                        <i class="fa-solid fa-plug"></i>
                    </a>
                </div>
                {{/if}}
            </div>
            {{/each}}
        </div>
    </div>
    <div class="header sub">
        {{@root.i18n 'variables.title'}}
    </div>
    <div class="scroll variables">
        <div class="list">
            {{#each variables as |variable|}}
            <div class="variable" data-id="{{variable.id}}" data-action="select-variable"
                data-editable>
                <div class="name" style="--variable-color: {{variable.color}};">
                    <i class="fa-regular fa-circle"></i>
                    {{variable.label}}
                </div>
                {{#if variable.hasNodes}}
                <div class="controls">
                    <a data-action="tab-variable" {{{@root.i18n.tooltip 'variables.tab' }}}>
                        <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    </a>
                </div>
                {{/if}}
            </div>
            {{/each}}
        </div>
    </div>
</div>
{{#unless (and isFree (not trigger.name includeZero=true))}}
<div class="trigger-title">
    {{#if trigger.locked}}
    <i class="fa-solid fa-plug-circle-xmark"></i>
    {{/if}}
    <div class="label">
        {{trigger.label}}
    </div>
</div>
{{/unless}}
<a class="window-collapsed" data-action="expand-window">
    <i class="fa-solid fa-expand"></i>
    {{@root.i18n 'expand'}}
</a>